# SQLite target. Relative values must be normalized paths below data/;
# an external ledger must use its canonical absolute path.
DB_FILE_NAME=data/finance.db
# Privacy: disable Next.js anonymous telemetry. Keep this set.
NEXT_TELEMETRY_DISABLED=1
# Extra origins allowed to invoke Server Actions through a reverse proxy,
# comma-separated (Tailscale *.ts.net is always allowed). Only needed for
# Headscale or custom domains, e.g.: finance.example.internal
#EXTRA_ALLOWED_ORIGINS=
