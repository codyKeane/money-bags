{
  "name": "repo",
  "version": "0.1.0",
  "private": true,
  "moneybagsRepositoryRoot": true,
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "dev": "node scripts/run-next.mjs dev",
    "build": "node scripts/run-with-temp-db.mjs build",
    "check:build-privacy": "node scripts/check-build-privacy.mjs",
    "validate:build-privacy": "node scripts/validate-build-privacy.mjs",
    "start": "node scripts/run-next.mjs start",
    "lint": "node scripts/run-with-temp-db.mjs lint",
    "test": "node scripts/run-with-temp-db.mjs test",
    "test:watch": "node scripts/run-with-temp-db.mjs test:watch",
    "smoke:dev": "node scripts/smoke-server.mjs dev",
    "smoke:start": "node scripts/smoke-server.mjs start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "import": "tsx scripts/import-csv.ts",
    "dev:lan": "node scripts/run-next.mjs dev:lan",
    "start:lan": "node scripts/run-next.mjs start:lan",
    "db:backup": "tsx scripts/backup-db.ts",
    "db:verify-backup": "tsx scripts/verify-backup.ts",
    "db:restore": "tsx scripts/restore-db.ts",
    "audit:data-path": "node --import ./scripts/disable-tsx-cache.mjs --import tsx scripts/audit-data-path.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "csv-parse": "^7.0.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
